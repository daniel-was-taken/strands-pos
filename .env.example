# =============================================================================
# strands-pos Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# Delete all comments in the .env file after filling in values to avoid errors
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL for request state persistence)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/database

# -----------------------------------------------------------------------------
# Neon MCP Connection (for database operations via MCP)
# -----------------------------------------------------------------------------
NEON_API_KEY=                     # Your Neon API key from https://console.neon.tech

NEON_PROJECT_ID=                  # Neon project ID (e.g., "proj-xxx-xxx")

NEON_DATABASE=                    # Database name (typically "neondb")

NEON_BRANCH_ID=                   # Branch ID (e.g., "br-xxx-xxx" or "main")

# Optional: Override the default MCP endpoint
# NEON_MCP_URL=https://mcp.neon.tech/mcp

# -----------------------------------------------------------------------------
# Gemini Model Configuration
# -----------------------------------------------------------------------------
# Option A: Google AI Studio (local development)
GOOGLE_API_KEY=                   # API key from https://aistudio.google.com/

# Option B: Vertex AI (Cloud Run / production)
# Requires: gcloud auth application-default login
# GOOGLE_CLOUD_PROJECT=           # Your GCP project ID
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional: Override the default model
# GEMINI_MODEL_ID=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR